# Copy to .env.local and fill in. None of these are committed.

# --- Google Maps ---
# Interactive map in the wizard (browser-side; restrict by HTTP referrer in
# Google Cloud Console - the key is public in the bundle). Static Maps for the
# PDF uses the same key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Google Drive (OAuth2 refresh-token auth) ---
# Folder structure FVyyNNN - ClientName + proposal PDF upload + signed
# contract delivery via the DocuSeal webhook.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
PARENT_FOLDER_ID=

# --- Upstash Redis ---
# Shared proposals (/s/<id> links), proposal -> Drive folder mapping for the
# DocuSeal webhook, and API rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Anthropic ---
# Utility-bill scanner (scan-bill server action).
ANTHROPIC_API_KEY=

# --- MarkItDown microservice (optional) ---
# Text-extraction path for the bill scanner; when unset or unreachable the
# scanner falls back to Claude vision.
MARKITDOWN_SERVICE_URL=
MARKITDOWN_API_KEY=

# --- DocuSeal Cloud (contract e-signing) ---
DOCUSEAL_API_KEY=
DOCUSEAL_API_URL=https://api.docuseal.com
# Optional: when set, /api/docuseal/webhook rejects requests without a valid
# X-Docuseal-Signature (hex HMAC-SHA256 of the body). Set it in DocuSeal
# dashboard -> Settings -> Webhooks too.
DOCUSEAL_WEBHOOK_SECRET=

# --- Remote MCP server (/api/mcp) ---
# Optional shared secret. When set, requests need ?key=<token> or an
# Authorization: Bearer header; otherwise the endpoint answers 404.
# Leave unset for an open server in local dev.
MCP_AUTH_TOKEN=
# Optional public origin for /s/<id> links built by create_quotation_link.
# Defaults to https://$VERCEL_PROJECT_PRODUCTION_URL, then localhost:3000.
MCP_PUBLIC_BASE_URL=

# PVGIS needs no key - free EU JRC service, climate-based fallback when down.
